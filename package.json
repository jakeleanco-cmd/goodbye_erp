{
  "name": "goodbye",
  "version": "1.0.0",
  "description": "사후 연락처 정리 및 계정 상속 서비스 GoodBye",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "nodemon --watch server server/dev.js",
    "dev:client": "npm run dev --prefix client",
    "build": "cd client && npm run build",
    "vercel-build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.14"
  }
}
